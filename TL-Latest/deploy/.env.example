# Copy this file to .env and fill in your values
# chmod 600 .env  (keep it private)

# --- Required ---
API_ID=your_telegram_api_id
API_HASH=your_telegram_api_hash
APP_PASSWORD=choose_a_strong_password
SESSION_SECRET=any_long_random_string_32+chars

# --- Database (optional — defaults to SQLite if not set) ---
# For SQLite (simplest, fine for personal use):
# DATABASE_URL=   <-- leave blank or omit entirely
#
# For PostgreSQL (better for concurrent use):
# DATABASE_URL=postgresql://user:password@localhost/tgviewer
